generator client {
  provider = "prisma-client"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model channels {
  id          String   @id
  name        String   @unique
  description String?
  avatar      String?
  banner      String?
  owner_id    String
  created_at  DateTime @default(now())
  updated_at  DateTime
  users       users    @relation(fields: [owner_id], references: [id])
  videos      videos[]
}

model comments {
  id         String   @id
  message    String   @unique
  user_id    String
  video_id   String
  created_at DateTime @default(now())
  updated_at DateTime
  users      users    @relation(fields: [user_id], references: [id])
  videos     videos   @relation(fields: [video_id], references: [id])
}

model likes {
  id         String   @id
  user_id    String
  video_id   String
  created_at DateTime @default(now())
  updated_at DateTime
  users      users    @relation(fields: [user_id], references: [id])
  videos     videos   @relation(fields: [video_id], references: [id])

  @@unique([user_id, video_id])
}

model users {
  id         String     @id
  mail       String     @unique
  password   String
  username   String     @unique
  avatar     String?
  created_at DateTime   @default(now())
  updated_at DateTime
  channels   channels[]
  comments   comments[]
  likes      likes[]
}

model videos {
  id          String     @id
  name        String     @unique
  description String?
  preview     String?
  views       Int        @default(0)
  channel_id  String
  created_at  DateTime   @default(now())
  updated_at  DateTime
  comments    comments[]
  likes       likes[]
  channels    channels   @relation(fields: [channel_id], references: [id])
}
