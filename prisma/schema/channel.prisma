model Channel {
  id String @id @default(cuid())

  name String @unique
  description String?
  avatar String?
  banner String?

  ownerId String @map("owner_id")
  owner User @relation(fields: [ownerId], references: [id])

  videos Video[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("channels")
}